{
  "name": "stuur-gateway",
  "version": "0.1.0",
  "description": "Telegram gateway for Stuur personal AI assistant",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "docker:build": "docker build -t stuur-gateway .",
    "docker:run": "docker run -d --name stuur-gateway --env-file .env stuur-gateway",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs stuur-gateway",
    "pm2:status": "pm2 status",
    "pm2:monitor": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup"
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "assistant",
    "grammy"
  ],
  "author": "Jos",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "grammy": "^1.34.0",
    "pino": "^9.3.1",
    "pino-pretty": "^11.0.0",
    "pm2": "^6.0.14",
    "surrealdb.js": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
